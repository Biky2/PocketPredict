# PocketPredict environment variables
# Copy this file to .env.local and fill in your own values.

# Optional site base URL for metadata and sitemap generation.
NEXT_PUBLIC_SITE_URL=https://pocketpredict.com

# Optional Google Analytics measurement ID.
NEXT_PUBLIC_GA_ID=

# Optional Cloudflare Turnstile public key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key for server-side Turnstile verification.
TURNSTILE_SECRET_KEY=

# Optional Cloudflare Turnstile public key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key for server-side Turnstile verification.
TURNSTILE_SECRET_KEY=
